# TACEDGE Environment Variables — EXAMPLE FILE (safe to commit)
# Copy this to .env and fill in real values. Never commit .env itself.

# Session encryption secret — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-session-secret-here

# AES-256 message encryption key (must be exactly 64 hex characters = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Once set and messages exist, do NOT change this key — old messages will be unreadable
ENCRYPTION_KEY=your-64-char-hex-key-here

NODE_ENV=production
